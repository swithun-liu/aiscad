          }
        },
        "additionalProperties": false
      },
      "llm": {
        "webSupported": true,
        "summary": "按控制点生成贝塞尔路径",
        "requiredParams": [
          "controlPoints"
        ],
        "paramGuide": {
          "controlPoints": "point2[]，二维点数组。 控制点列表，用于贝塞尔路径。",
          "segments": "integer，整数，或 {\"$var\":\"变量名\"}。 分段数，越大越圆滑。"
        },
        "constraints": [],
        "whenToUse": [
          "需要先描述二维路径，再决定是否闭合成草图时使用。",
          "当后续会拼接路径、闭合轮廓或沿路径扫掠时使用。"
        ],
        "whenNotToUse": [
          "不要把 curve2 直接当成最终可打印实体输出。"
        ],
        "commonMistakes": [
          "路径点顺序混乱，导致轮廓方向或闭合关系异常。",
          "把开路径误当成可直接拉伸的封闭草图。"
        ],
        "recommendedBefore": [],
        "recommendedAfter": [
          "curve.close",
          "sketch.fromCurve",
          "construct.extrudeRectangular"
        ],
        "stabilityNotes": [
          "复杂实体优先先得到稳定的二维轮廓，再进入 sketch 或 construct 阶段。"
        ],
        "inputExpectation": "该 action 不依赖前序几何输入。",
        "outputMeaning": "输出是二维路径，不具备面积与厚度，通常用于闭合、扫掠或转成草图。",
        "example": {
          "id": "curve_bezier_example",
          "action": "curve.bezier",
          "params": {
            "controlPoints": [
              [
                0,
                0
              ],
              [
                20,
                30
              ],
              [
                40,
                0
              ]
            ],
            "segments": 32
          }
        }
      }
    },
    "curve.concat": {
      "role": "拼接多个路径，保持路径语义",
      "inputKinds": [
        "curve2"
      ],
      "outputKind": "curve2",
      "paramsSchema": {
        "type": "object",
        "required": [
          "sources"
        ],
        "properties": {
          "sources": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/refList"
          },
          "closed": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/booleanValue",
            "default": false
          }
        },
        "additionalProperties": false
      },
      "llm": {
        "webSupported": true,
        "summary": "拼接多个路径，保持路径语义",
        "requiredParams": [
          "sources"
        ],
        "paramGuide": {
          "sources": "ref[]，字符串数组，引用多个前序 action 的 id。 多个输入对象引用数组。",
          "closed": "boolean，布尔值，或 {\"$var\":\"变量名\"}。 是否闭合路径或扫掠轨迹。 默认值 false。"
        },
        "constraints": [],
        "whenToUse": [
          "需要先描述二维路径，再决定是否闭合成草图时使用。",
          "当后续会拼接路径、闭合轮廓或沿路径扫掠时使用。"
        ],
        "whenNotToUse": [
          "不要把 curve2 直接当成最终可打印实体输出。"
        ],
        "commonMistakes": [
          "路径点顺序混乱，导致轮廓方向或闭合关系异常。",
          "把开路径误当成可直接拉伸的封闭草图。"
        ],
        "recommendedBefore": [],
        "recommendedAfter": [
          "curve.close",
          "sketch.fromCurve",
          "construct.extrudeRectangular"
        ],
        "stabilityNotes": [
          "复杂实体优先先得到稳定的二维轮廓，再进入 sketch 或 construct 阶段。"
        ],
        "inputExpectation": "输入通常来自这些类型之一：curve2。",
        "outputMeaning": "输出是二维路径，不具备面积与厚度，通常用于闭合、扫掠或转成草图。",
        "example": {
          "id": "curve_concat_example",
          "action": "curve.concat",
          "params": {
            "sources": [
              "path_a",
              "path_b"
            ],
            "closed": false
          }
        }
      }
