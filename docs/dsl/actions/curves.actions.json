{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aiscad.dsl/actions/curves",
  "category": "curves",
  "produces": [
    "curve2"
  ],
  "actions": {
    "curve.line": {
      "role": "按点序生成折线路径，可开可闭",
      "inputKinds": [],
      "outputKind": "curve2",
      "paramsSchema": {
        "type": "object",
        "required": [
          "points"
        ],
        "properties": {
          "points": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/point2List"
          },
          "closed": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/booleanValue",
            "default": false
          }
        },
        "additionalProperties": false
      },
      "llm": {
        "webSupported": true,
        "summary": "按点序生成折线路径，可开可闭",
        "requiredParams": [
          "points"
        ],
        "paramGuide": {
          "points": "point2[]，二维点数组。 点列表，按顺序定义轮廓或路径。",
          "closed": "boolean，布尔值，或 {\"$var\":\"变量名\"}。 是否闭合路径或扫掠轨迹。 默认值 false。"
        },
        "constraints": [],
        "whenToUse": [
          "需要先描述二维路径，再决定是否闭合成草图时使用。",
          "当后续会拼接路径、闭合轮廓或沿路径扫掠时使用。"
        ],
        "whenNotToUse": [
          "不要把 curve2 直接当成最终可打印实体输出。"
        ],
        "commonMistakes": [
          "路径点顺序混乱，导致轮廓方向或闭合关系异常。",
          "把开路径误当成可直接拉伸的封闭草图。"
        ],
        "recommendedBefore": [],
        "recommendedAfter": [
          "curve.close",
          "sketch.fromCurve",
          "construct.extrudeRectangular"
        ],
        "stabilityNotes": [
          "复杂实体优先先得到稳定的二维轮廓，再进入 sketch 或 construct 阶段。"
        ],
        "inputExpectation": "该 action 不依赖前序几何输入。",
        "outputMeaning": "输出是二维路径，不具备面积与厚度，通常用于闭合、扫掠或转成草图。",
        "example": {
          "id": "curve_line_example",
          "action": "curve.line",
          "params": {
            "points": [
              [
                0,
                0
              ],
              [
                40,
                0
              ],
              [
                40,
                20
              ],
              [
                0,
                20
              ]
            ],
            "closed": false
          }
        }
      }
    },
    "curve.arc": {
      "role": "生成圆弧路径",
      "inputKinds": [],
      "outputKind": "curve2",
      "paramsSchema": {
        "type": "object",
        "required": [
          "center",
          "radius",
          "startAngle",
          "endAngle"
        ],
        "properties": {
          "center": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/vector2"
          },
          "radius": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/numberValue"
          },
          "startAngle": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/numberValue"
          },
          "endAngle": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/numberValue"
          },
          "segments": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/integerValue"
          }
        },
        "additionalProperties": false
      },
      "llm": {
        "webSupported": true,
        "summary": "生成圆弧路径",
        "requiredParams": [
          "center",
          "radius",
          "startAngle",
          "endAngle"
        ],
        "paramGuide": {
          "center": "vector2，长度为 2 的数值数组。 中心点坐标。",
          "radius": "number，数值，或 {\"$var\":\"变量名\"}。 半径。",
          "startAngle": "number，数值，或 {\"$var\":\"变量名\"}。 起始角度，单位为度。",
          "endAngle": "number，数值，或 {\"$var\":\"变量名\"}。 结束角度，单位为度。",
          "segments": "integer，整数，或 {\"$var\":\"变量名\"}。 分段数，越大越圆滑。"
        },
        "constraints": [],
        "whenToUse": [
          "需要先描述二维路径，再决定是否闭合成草图时使用。",
          "当后续会拼接路径、闭合轮廓或沿路径扫掠时使用。"
        ],
        "whenNotToUse": [
          "不要把 curve2 直接当成最终可打印实体输出。"
        ],
        "commonMistakes": [
          "路径点顺序混乱，导致轮廓方向或闭合关系异常。",
          "把开路径误当成可直接拉伸的封闭草图。"
        ],
        "recommendedBefore": [],
        "recommendedAfter": [
          "curve.close",
          "sketch.fromCurve",
          "construct.extrudeRectangular"
        ],
        "stabilityNotes": [
          "复杂实体优先先得到稳定的二维轮廓，再进入 sketch 或 construct 阶段。"
        ],
        "inputExpectation": "该 action 不依赖前序几何输入。",
        "outputMeaning": "输出是二维路径，不具备面积与厚度，通常用于闭合、扫掠或转成草图。",
        "example": {
          "id": "curve_arc_example",
          "action": "curve.arc",
          "params": {
            "center": [
              0,
              0
            ],
            "radius": 10,
            "startAngle": 0,
            "endAngle": 180,
            "segments": 32
          }
        }
      }
    },
    "curve.bezier": {
      "role": "按控制点生成贝塞尔路径",
      "inputKinds": [],
      "outputKind": "curve2",
