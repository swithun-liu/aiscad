    "curve.close": {
      "role": "将开路径闭合为闭路径",
      "inputKinds": [
        "curve2"
      ],
      "outputKind": "curve2",
      "paramsSchema": {
        "type": "object",
        "required": [
          "source"
        ],
        "properties": {
          "source": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/ref"
          }
        },
        "additionalProperties": false
      },
      "llm": {
        "webSupported": true,
        "summary": "将开路径闭合为闭路径",
        "requiredParams": [
          "source"
        ],
        "paramGuide": {
          "source": "ref，字符串，引用前序 action 的 id。 单个输入对象引用，值必须是前面 action 的 id。"
        },
        "constraints": [],
        "whenToUse": [
          "需要先描述二维路径，再决定是否闭合成草图时使用。",
          "当后续会拼接路径、闭合轮廓或沿路径扫掠时使用。"
        ],
        "whenNotToUse": [
          "不要把 curve2 直接当成最终可打印实体输出。"
        ],
        "commonMistakes": [
          "路径点顺序混乱，导致轮廓方向或闭合关系异常。",
          "把开路径误当成可直接拉伸的封闭草图。"
        ],
        "recommendedBefore": [],
        "recommendedAfter": [
          "curve.close",
          "sketch.fromCurve",
          "construct.extrudeRectangular"
        ],
        "stabilityNotes": [
