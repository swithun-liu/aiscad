{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aiscad.dsl/actions/transforms",
  "category": "transforms",
  "preservesTopology": true,
  "actions": {
    "transform.translate": {
      "role": "平移几何",
      "inputKinds": [
        "curve2",
        "geom2",
        "geom3",
        "group"
      ],
      "outputKind": "same-as-source",
      "paramsSchema": {
        "type": "object",
        "required": [
          "source",
          "offset"
        ],
        "properties": {
          "source": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/ref"
          },
          "offset": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/vector3"
          }
        },
        "additionalProperties": false
      },
      "llm": {
        "webSupported": true,
        "summary": "平移几何",
        "requiredParams": [
          "source",
          "offset"
        ],
        "paramGuide": {
          "source": "ref，字符串，引用前序 action 的 id。 单个输入对象引用，值必须是前面 action 的 id。",
          "offset": "vector3，长度为 3 的数值数组。 位移向量。"
        },
        "constraints": [],
        "whenToUse": [
          "需要在不改变几何本质的前提下调整位置、姿态或尺度时使用。"
        ],
        "whenNotToUse": [
          "不要用 transform 代替本应在 primitive/construct 阶段直接表达的尺寸信息。"
        ],
        "commonMistakes": [
          "在阵列和布尔前忘记统一坐标基准，导致对象错位。"
        ],
        "recommendedBefore": [],
        "recommendedAfter": [
          "boolean.union",
          "boolean.subtract",
          "pattern.linear",
          "pattern.grid",
          "pattern.radial"
        ],
        "stabilityNotes": [
          "尽量先得到简单稳定的对象，再做 transform，而不是在草图阶段混入过多偏移。"
        ],
        "inputExpectation": "输入通常来自这些类型之一：curve2 / geom2 / geom3 / group。",
        "outputMeaning": "输出类型为 same-as-source，需结合上下文理解后续用法。",
        "example": {
          "id": "transform_translate_example",
          "action": "transform.translate",
          "params": {
            "source": "body",
            "offset": [
              10,
              0,
              0
            ]
          }
        }
      }
    },
    "transform.rotate": {
      "role": "按 XYZ 欧拉角旋转几何",
      "inputKinds": [
        "curve2",
        "geom2",
        "geom3",
        "group"
      ],
      "outputKind": "same-as-source",
      "paramsSchema": {
        "type": "object",
        "required": [
          "source",
          "angles"
        ],
        "properties": {
          "source": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/ref"
          },
          "angles": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/vector3"
          },
          "origin": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/vector3",
            "default": [
              0,
              0,
              0
            ]
          }
        },
        "additionalProperties": false
      },
      "llm": {
        "webSupported": true,
        "summary": "按 XYZ 欧拉角旋转几何",
        "requiredParams": [
          "source",
          "angles"
        ],
        "paramGuide": {
          "source": "ref，字符串，引用前序 action 的 id。 单个输入对象引用，值必须是前面 action 的 id。",
          "angles": "vector3，长度为 3 的数值数组。 XYZ 欧拉角，单位为度。",
          "origin": "vector3，长度为 3 的数值数组。 阵列起始偏移。 默认值 [0, 0, 0]。"
        },
        "constraints": [],
        "whenToUse": [
          "需要在不改变几何本质的前提下调整位置、姿态或尺度时使用。"
        ],
        "whenNotToUse": [
          "不要用 transform 代替本应在 primitive/construct 阶段直接表达的尺寸信息。"
        ],
        "commonMistakes": [
          "在阵列和布尔前忘记统一坐标基准，导致对象错位。"
        ],
        "recommendedBefore": [],
        "recommendedAfter": [
          "boolean.union",
          "boolean.subtract",
          "pattern.linear",
          "pattern.grid",
          "pattern.radial"
        ],
        "stabilityNotes": [
          "尽量先得到简单稳定的对象，再做 transform，而不是在草图阶段混入过多偏移。"
        ],
        "inputExpectation": "输入通常来自这些类型之一：curve2 / geom2 / geom3 / group。",
        "outputMeaning": "输出类型为 same-as-source，需结合上下文理解后续用法。",
        "example": {
          "id": "transform_rotate_example",
          "action": "transform.rotate",
          "params": {
            "source": "body",
            "angles": [
              0,
              0,
              90
            ],
            "origin": [
              0,
              0,
              0
            ]
          }
        }
      }
    },
    "transform.scale": {
      "role": "按轴缩放几何",
      "inputKinds": [
        "curve2",
        "geom2",
        "geom3",
        "group"
