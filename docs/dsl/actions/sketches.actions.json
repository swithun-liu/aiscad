        "requiredParams": [
          "source"
        ],
        "paramGuide": {
          "source": "ref，字符串，引用前序 action 的 id。 单个输入对象引用，值必须是前面 action 的 id。"
        },
        "constraints": [],
        "whenToUse": [
          "需要生成二维截面、轮廓或拉伸前草图时使用。",
          "当目标实体适合先 2D 后 3D 的稳定建模路径时优先使用。"
