      "llm": {
        "webSupported": false,
        "summary": "生成文本轮廓草图，适合压印和雕刻",
        "requiredParams": [
          "text",
          "fontSize"
        ],
        "paramGuide": {
          "text": "string，字符串，或 {\"$var\":\"变量名\"}。 文本内容。",
          "fontSize": "number，数值，或 {\"$var\":\"变量名\"}。 字体尺寸。",
          "align": "enum，可选值：left / center / right。 文本对齐方式。 默认值 \"left\"。",
          "lineSpacing": "number，数值，或 {\"$var\":\"变量名\"}。 行间距。",
          "letterSpacing": "number，数值，或 {\"$var\":\"变量名\"}。 字间距。",
          "position": "vector2，长度为 2 的数值数组。 文本位置。 默认值 [0, 0]。"
        },
        "constraints": [],
        "whenToUse": [
          "需要生成二维截面、轮廓或拉伸前草图时使用。",
          "当目标实体适合先 2D 后 3D 的稳定建模路径时优先使用。"
        ],
