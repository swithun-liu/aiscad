              0
            ]
          },
          "radius": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/numberValue"
          },
          "style": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/cornerStyle",
            "default": "round"
          },
          "segments": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/integerValue"
          }
        },
        "additionalProperties": false
      },
