          "modify.offset2d",
          "boolean.subtract"
        ],
        "stabilityNotes": [
          "板件、孔槽、法兰轮廓通常优先先草图后拉伸。"
        ],
        "inputExpectation": "输入通常来自这些类型之一：curve2。",
        "outputMeaning": "输出是二维草图/截面，没有厚度，通常需要进一步构造为实体。",
        "example": {
          "id": "sketch_fromCurve_example",
          "action": "sketch.fromCurve",
          "params": {
            "source": "closed_path"
          }
        }
      }
