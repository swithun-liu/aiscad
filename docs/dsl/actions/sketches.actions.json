{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aiscad.dsl/actions/sketches",
  "category": "sketches",
  "produces": [
    "geom2"
  ],
  "actions": {
    "sketch.circle": {
      "role": "生成圆形草图",
      "inputKinds": [],
      "outputKind": "geom2",
      "paramsSchema": {
        "type": "object",
        "required": [
          "radius"
        ],
        "properties": {
          "radius": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/numberValue"
          },
          "center": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/vector2",
            "default": [
              0,
              0
            ]
          },
          "segments": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/integerValue"
          }
        },
        "additionalProperties": false
      },
      "llm": {
        "webSupported": true,
        "summary": "生成圆形草图",
        "requiredParams": [
          "radius"
        ],
        "paramGuide": {
          "radius": "number，数值，或 {\"$var\":\"变量名\"}。 半径。",
          "center": "vector2，长度为 2 的数值数组。 中心点坐标。 默认值 [0, 0]。",
          "segments": "integer，整数，或 {\"$var\":\"变量名\"}。 分段数，越大越圆滑。"
        },
        "constraints": [],
        "whenToUse": [
          "需要生成二维截面、轮廓或拉伸前草图时使用。",
          "当目标实体适合先 2D 后 3D 的稳定建模路径时优先使用。"
        ],
        "whenNotToUse": [
          "不要把 geom2 当成已经具有厚度的实体理解。"
        ],
        "commonMistakes": [
          "草图还未封闭就直接进入实体构造。",
          "把过多细节堆在单个草图里，导致后续布尔难维护。"
        ],
        "recommendedBefore": [],
        "recommendedAfter": [
          "construct.extrudeLinear",
          "modify.offset2d",
          "boolean.subtract"
        ],
        "stabilityNotes": [
          "板件、孔槽、法兰轮廓通常优先先草图后拉伸。"
        ],
        "inputExpectation": "该 action 不依赖前序几何输入。",
        "outputMeaning": "输出是二维草图/截面，没有厚度，通常需要进一步构造为实体。",
        "example": {
          "id": "sketch_circle_example",
          "action": "sketch.circle",
          "params": {
            "radius": 12,
            "center": [
              0,
              0
            ],
            "segments": 32
          }
        }
      }
    },
