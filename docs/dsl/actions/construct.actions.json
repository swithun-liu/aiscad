{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aiscad.dsl/actions/construct",
  "category": "construct",
  "actions": {
    "construct.extrudeLinear": {
      "role": "将二维草图沿法向线性拉伸成实体",
      "inputKinds": [
        "geom2"
      ],
      "outputKind": "geom3",
      "paramsSchema": {
        "type": "object",
        "required": [
          "source",
          "height"
        ],
        "properties": {
          "source": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/ref"
          },
          "height": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/numberValue"
          },
          "twistAngle": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/numberValue",
            "default": 0
          },
          "twistSteps": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/integerValue",
            "default": 1
          }
        },
        "additionalProperties": false
      },
      "llm": {
        "webSupported": true,
        "summary": "将二维草图沿法向线性拉伸成实体",
        "requiredParams": [
          "source",
          "height"
        ],
        "paramGuide": {
          "source": "ref，字符串，引用前序 action 的 id。 单个输入对象引用，值必须是前面 action 的 id。",
          "height": "number，数值，或 {\"$var\":\"变量名\"}。 高度。",
          "twistAngle": "number，数值，或 {\"$var\":\"变量名\"}。 拉伸扭转角度，单位为度。 默认值 0。",
          "twistSteps": "integer，整数，或 {\"$var\":\"变量名\"}。 扭转插值步数。 默认值 1。"
        },
        "constraints": [],
        "whenToUse": [
          "需要把二维信息提升为三维实体，或在 2D/3D 之间转换时使用。",
          "板件、法兰、孔槽、轮廓类实体通常优先用它从稳定草图得到实体。"
        ],
        "whenNotToUse": [
          "不要跳过输入对象类型约束，例如用 curve2 去线性拉伸。"
        ],
        "commonMistakes": [
          "把 2D 中间态当成最终实体结果。",
          "对不稳定草图直接拉伸，导致后续布尔复杂度升高。",
          "source 仍是开路径或无效草图。",
          "得到 geom3 后又继续按二维心智理解结果。"
        ],
        "recommendedBefore": [
          "sketch.rectangle",
          "sketch.circle",
          "sketch.polygon",
          "sketch.fromCurve"
        ],
        "recommendedAfter": [
          "transform.translate",
          "boolean.subtract",
          "display.color",
          "boolean.union"
        ],
        "stabilityNotes": [
          "构造类 action 通常是从草图阶段进入实体阶段的关键分界点。",
          "这是从二维草图进入可打印实体的常见稳定路径。"
        ],
        "inputExpectation": "输入通常来自这些类型之一：geom2。",
        "outputMeaning": "输出是三维实体，可作为可打印或实体布尔阶段的基础。",
        "example": {
          "id": "construct_extrudeLinear_example",
          "action": "construct.extrudeLinear",
          "params": {
            "source": "profile",
            "height": 20,
            "twistAngle": 0,
            "twistSteps": 1
          }
        }
      }
    },
    "construct.extrudeRotate": {
      "role": "将二维剖面绕轴旋转生成回转体",
      "inputKinds": [
        "geom2"
      ],
      "outputKind": "geom3",
      "paramsSchema": {
        "type": "object",
        "required": [
          "source"
        ],
        "properties": {
          "source": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/ref"
          },
          "angle": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/numberValue",
            "default": 360
          },
          "segments": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/integerValue",
            "default": 32,
            "minimum": 4
          },
          "axis": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/axis",
            "default": "z"
          }
        },
        "additionalProperties": false
      },
      "llm": {
        "webSupported": true,
        "summary": "将二维剖面绕轴旋转生成回转体",
        "requiredParams": [
          "source"
        ],
        "paramGuide": {
          "source": "ref，字符串，引用前序 action 的 id。 单个输入对象引用，值必须是前面 action 的 id。",
          "angle": "number，数值，或 {\"$var\":\"变量名\"}。 旋转总角度，单位为度。 默认值 360。",
          "segments": "integer，整数，或 {\"$var\":\"变量名\"}。 分段数，越大越圆滑；省略时默认 32，若填写则必须大于等于 4。",
          "axis": "enum，只能是 x、y、z。 坐标轴，只能是 x / y / z。 默认值 \"z\"。"
        },
        "constraints": [
          "segments 省略时默认使用 32。",
          "segments 若填写，必须大于等于 4。"
        ],
        "whenToUse": [
          "需要把二维信息提升为三维实体，或在 2D/3D 之间转换时使用。"
        ],
        "whenNotToUse": [
          "不要跳过输入对象类型约束，例如用 curve2 去线性拉伸。"
        ],
        "commonMistakes": [
          "把 2D 中间态当成最终实体结果。",
          "对不稳定草图直接拉伸，导致后续布尔复杂度升高。"
        ],
        "recommendedBefore": [
          "sketch.rectangle",
          "sketch.circle",
          "sketch.polygon",
          "sketch.fromCurve"
        ],
        "recommendedAfter": [
          "transform.translate",
          "boolean.subtract",
          "display.color"
        ],
        "stabilityNotes": [
          "构造类 action 通常是从草图阶段进入实体阶段的关键分界点。"
        ],
        "inputExpectation": "输入通常来自这些类型之一：geom2。",
        "outputMeaning": "输出是三维实体，可作为可打印或实体布尔阶段的基础。",
        "example": {
          "id": "construct_extrudeRotate_example",
          "action": "construct.extrudeRotate",
          "params": {
            "source": "profile",
            "angle": 360,
            "segments": 32,
            "axis": "z"
          }
        }
      }
    },
    "construct.extrudeRectangular": {
      "role": "沿二维路径扫掠矩形截面",
      "inputKinds": [
        "curve2"
      ],
      "outputKind": "geom3",
      "paramsSchema": {
        "type": "object",
        "required": [
          "source",
          "size"
        ],
        "properties": {
          "source": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/ref"
          },
          "size": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/vector2"
          },
          "closed": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/booleanValue",
            "default": false
          },
          "caps": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/caps",
            "default": "both"
          }
        },
        "additionalProperties": false
      },
      "llm": {
        "webSupported": true,
        "summary": "沿二维路径扫掠矩形截面",
        "requiredParams": [
          "source",
          "size"
        ],
        "paramGuide": {
          "source": "ref，字符串，引用前序 action 的 id。 单个输入对象引用，值必须是前面 action 的 id。",
          "size": "vector2，长度为 2 的数值数组。 尺寸向量。2D 时为 [x, y]，3D 时为 [x, y, z]。",
          "closed": "boolean，布尔值，或 {\"$var\":\"变量名\"}。 是否闭合路径或扫掠轨迹。 默认值 false。",
          "caps": "enum，可选值为 none / start / end / both。 路径扫掠两端封口方式。 默认值 \"both\"。"
        },
        "constraints": [],
        "whenToUse": [
          "需要把二维信息提升为三维实体，或在 2D/3D 之间转换时使用。"
        ],
        "whenNotToUse": [
          "不要跳过输入对象类型约束，例如用 curve2 去线性拉伸。"
        ],
        "commonMistakes": [
          "把 2D 中间态当成最终实体结果。",
          "对不稳定草图直接拉伸，导致后续布尔复杂度升高。"
        ],
        "recommendedBefore": [
          "sketch.rectangle",
          "sketch.circle",
          "sketch.polygon",
          "sketch.fromCurve"
        ],
        "recommendedAfter": [
          "transform.translate",
          "boolean.subtract",
          "display.color"
        ],
        "stabilityNotes": [
          "构造类 action 通常是从草图阶段进入实体阶段的关键分界点。"
        ],
        "inputExpectation": "输入通常来自这些类型之一：curve2。",
        "outputMeaning": "输出是三维实体，可作为可打印或实体布尔阶段的基础。",
        "example": {
          "id": "construct_extrudeRectangular_example",
          "action": "construct.extrudeRectangular",
          "params": {
            "source": "path",
            "size": [
              4,
              10
            ],
            "closed": false,
            "caps": "both"
          }
        }
      }
    },
    "construct.extrudeFromSlices": {
      "role": "通过一系列切片插值生成复杂扫掠实体",
      "inputKinds": [
        "geom2"
      ],
      "outputKind": "geom3",
      "paramsSchema": {
        "type": "object",
        "required": [
          "source",
          "slices"
        ],
        "properties": {
          "source": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/ref"
          },
          "slices": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "required": [
                "offset"
              ],
              "properties": {
                "offset": {
                  "$ref": "aiscad.dsl/actions/common.types#/$defs/numberValue"
                },
                "translate": {
                  "$ref": "aiscad.dsl/actions/common.types#/$defs/vector3"
                },
                "rotate": {
                  "$ref": "aiscad.dsl/actions/common.types#/$defs/vector3"
                },
                "scale": {
                  "$ref": "aiscad.dsl/actions/common.types#/$defs/vector2"
                }
              },
              "additionalProperties": false
            }
          },
          "close": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/booleanValue",
            "default": false
          }
        },
        "additionalProperties": false
      },
      "llm": {
        "webSupported": false,
        "summary": "通过一系列切片插值生成复杂扫掠实体",
        "requiredParams": [
          "source",
          "slices"
        ],
        "paramGuide": {
          "source": "ref，字符串，引用前序 action 的 id。 单个输入对象引用，值必须是前面 action 的 id。",
          "slices": "array，数组。 切片列表，用于按切片插值生成实体。",
          "close": "boolean，布尔值，或 {\"$var\":\"变量名\"}。 默认值 false。"
        },
        "constraints": [],
        "whenToUse": [
          "需要把二维信息提升为三维实体，或在 2D/3D 之间转换时使用。"
        ],
        "whenNotToUse": [
          "不要跳过输入对象类型约束，例如用 curve2 去线性拉伸。"
        ],
        "commonMistakes": [
          "把 2D 中间态当成最终实体结果。",
          "对不稳定草图直接拉伸，导致后续布尔复杂度升高。"
        ],
        "recommendedBefore": [
          "sketch.rectangle",
          "sketch.circle",
          "sketch.polygon",
          "sketch.fromCurve"
        ],
        "recommendedAfter": [
          "transform.translate",
          "boolean.subtract",
          "display.color"
        ],
        "stabilityNotes": [
          "构造类 action 通常是从草图阶段进入实体阶段的关键分界点。"
        ],
        "inputExpectation": "输入通常来自这些类型之一：geom2。",
        "outputMeaning": "输出是三维实体，可作为可打印或实体布尔阶段的基础。",
        "example": {
          "id": "construct_extrudeFromSlices_example",
          "action": "construct.extrudeFromSlices",
          "params": {
            "source": "profile",
            "slices": [
              {
                "offset": 0
              },
              {
                "offset": 20,
                "scale": [
                  0.8,
                  0.8
                ]
              }
            ],
            "close": false
          }
        }
      }
    },
    "construct.project": {
