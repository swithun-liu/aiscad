          },
          "mode": {
            "type": "string",
            "enum": [
              "orthographic",
              "section"
            ],
            "default": "orthographic"
          }
        },
        "additionalProperties": false
      },
      "llm": {
        "webSupported": true,
        "summary": "将三维实体投影为二维草图",
        "requiredParams": [
          "source"
        ],
        "paramGuide": {
          "source": "ref，字符串，引用前序 action 的 id。 单个输入对象引用，值必须是前面 action 的 id。",
          "axis": "enum，只能是 x、y、z。 坐标轴，只能是 x / y / z。 默认值 \"z\"。",
          "mode": "enum，可选值：orthographic / section。 投影模式。 默认值 \"orthographic\"。"
        },
        "constraints": [],
        "whenToUse": [
          "需要把二维信息提升为三维实体，或在 2D/3D 之间转换时使用。"
