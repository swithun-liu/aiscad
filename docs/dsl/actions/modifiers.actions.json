{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aiscad.dsl/actions/modifiers",
  "category": "modifiers",
  "actions": {
    "modify.offset2d": {
      "role": "对二维草图做偏移，适合壁厚、轮廓扩边",
      "inputKinds": [
        "geom2"
      ],
      "outputKind": "geom2",
      "paramsSchema": {
        "type": "object",
        "required": [
          "source",
          "distance"
        ],
        "properties": {
          "source": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/ref"
          },
          "distance": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/numberValue"
          },
          "corners": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/cornerStyle",
            "default": "round"
          },
          "segments": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/integerValue"
          }
        },
        "additionalProperties": false
      },
      "llm": {
        "webSupported": true,
        "summary": "对二维草图做偏移，适合壁厚、轮廓扩边",
        "requiredParams": [
          "source",
          "distance"
        ],
        "paramGuide": {
          "source": "ref，字符串，引用前序 action 的 id。 单个输入对象引用，值必须是前面 action 的 id。",
          "distance": "number，数值，或 {\"$var\":\"变量名\"}。 二维偏移距离。",
          "corners": "enum，可选值为 round / chamfer / edge。 角处理方式。 默认值 \"round\"。",
          "segments": "integer，整数，或 {\"$var\":\"变量名\"}。 分段数，越大越圆滑。"
        },
        "constraints": [],
        "whenToUse": [
          "需要做偏移、膨胀、清理、凸包等几何后处理时使用。"
        ],
        "whenNotToUse": [
          "不要用 modify 去掩盖前序草图或实体建模策略错误。"
        ],
        "commonMistakes": [
          "把 offset/expand 的结果当作严格尺寸控制而忽略边角变化。"
        ],
        "recommendedBefore": [],
        "recommendedAfter": [
          "construct.extrudeLinear",
          "boolean.subtract",
          "display.color"
        ],
        "stabilityNotes": [
          "modify 更适合作为精修或派生步骤，而不是主建模骨架。"
        ],
        "inputExpectation": "输入通常来自这些类型之一：geom2。",
        "outputMeaning": "输出是二维草图/截面，没有厚度，通常需要进一步构造为实体。",
        "example": {
          "id": "modify_offset2d_example",
          "action": "modify.offset2d",
          "params": {
            "source": "profile",
            "distance": 2,
            "corners": "round",
            "segments": 32
          }
        }
      }
    },
