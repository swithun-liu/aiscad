{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aiscad.dsl/actions/solids",
  "category": "solids",
  "produces": [
    "geom3"
  ],
  "actions": {
    "solid.box": {
      "role": "生成长方体",
      "inputKinds": [],
      "outputKind": "geom3",
      "paramsSchema": {
        "type": "object",
        "required": [
          "size"
        ],
        "properties": {
          "size": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/vector3"
          },
          "center": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/vector3",
            "default": [
              0,
              0,
              0
            ]
          }
        },
        "additionalProperties": false
      },
      "llm": {
        "webSupported": true,
        "summary": "生成长方体",
        "requiredParams": [
          "size"
        ],
        "paramGuide": {
          "size": "vector3，长度为 3 的数值数组。 尺寸向量。2D 时为 [x, y]，3D 时为 [x, y, z]。",
          "center": "vector3，长度为 3 的数值数组。 中心点坐标。 默认值 [0, 0, 0]。"
        },
        "constraints": [],
        "whenToUse": [
          "可以直接用基础体表达主体时优先使用。",
          "当结构接近标准几何原语时，优先用 solid 而不是复杂草图。"
        ],
        "whenNotToUse": [
          "不要为了拟合简单结构而放弃更稳定的 primitive 路线。"
        ],
        "commonMistakes": [
          "基础体尺寸与中心点理解错误，导致后续布尔位置整体偏移。"
        ],
        "recommendedBefore": [],
        "recommendedAfter": [
          "transform.translate",
          "transform.rotate",
          "boolean.union",
          "boolean.subtract"
        ],
        "stabilityNotes": [
          "primitive + transform + boolean 通常比一次性构造复杂轮廓更稳。"
        ],
        "inputExpectation": "该 action 不依赖前序几何输入。",
        "outputMeaning": "输出是三维实体，可作为可打印或实体布尔阶段的基础。",
        "example": {
          "id": "solid_box_example",
          "action": "solid.box",
          "params": {
            "size": [
              40,
              20,
              10
            ],
            "center": [
              0,
              0,
              0
            ]
          }
        }
      }
    },
    "solid.hollowBox": {
      "role": "生成带指定壁厚和开口方向的盒状壳体",
      "inputKinds": [],
      "outputKind": "geom3",
      "paramsSchema": {
        "type": "object",
        "required": [
          "size",
          "wallThickness"
        ],
        "properties": {
          "size": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/vector3"
          },
          "center": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/vector3",
            "default": [
              0,
              0,
              0
            ]
          },
          "wallThickness": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/numberValue",
            "exclusiveMinimum": 0
          },
          "openAxis": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/axis",
            "default": "z"
          },
          "openSide": {
            "type": "string",
            "enum": [
              "positive",
              "negative"
            ],
            "default": "negative"
          }
        },
        "additionalProperties": false
      },
      "llm": {
        "webSupported": true,
        "summary": "生成带指定壁厚和开口方向的盒状壳体",
        "requiredParams": [
          "size",
          "wallThickness"
        ],
        "paramGuide": {
          "size": "vector3，长度为 3 的数值数组。外部包络尺寸，即整个盒状壳体的总长宽高。",
          "center": "vector3，长度为 3 的数值数组。外部壳体中心点坐标。默认值 [0, 0, 0]。",
          "wallThickness": "number，数值，或 {\"$var\":\"变量名\"}。统一壁厚。非开口方向会保留两侧壁厚，开口方向只保留一侧壁厚。",
          "openAxis": "axis，字符串，只能是 x / y / z。壳体开口所沿的轴。默认值 \"z\"。",
          "openSide": "enum，可选值：positive / negative。壳体开口位于 openAxis 的正侧或负侧。默认值 \"negative\"。"
        },
        "constraints": [
          "wallThickness 必须大于 0。",
          "在非开口轴上，外尺寸必须大于 2 倍 wallThickness；在开口轴上，外尺寸必须大于 wallThickness。",
          "该 action 表达的是盒状壳体；size 是外尺寸，不是内腔尺寸。"
        ],
        "whenToUse": [
          "需要表达盒体、盒盖、托盘、外壳等规则盒状壳体，并且已知外尺寸、壁厚和开口方向时使用。",
          "当你本来会用 outer box 减 inner box 来手工构造壳体时，优先使用它。"
        ],
        "whenNotToUse": [
          "不要把它用于非盒状、强曲面或自由形体壳体。",
          "当需要不同面使用不同壁厚，或需要多个开口方向时，不要优先使用它。"
        ],
        "commonMistakes": [
          "把 size 当成内腔尺寸，导致整体外形比需求大一圈。",
          "把 wallThickness 只理解为侧壁厚度，却忘记开口对面的顶板也会保留该厚度。",
          "openAxis 或 openSide 选错，导致开口方向与预期相反。"
        ],
        "recommendedBefore": [],
        "recommendedAfter": [
          "boolean.subtract",
          "transform.translate",
          "display.color"
        ],
        "stabilityNotes": [
          "对于规则盒状壳体，solid.hollowBox 比手工用两个 box 做布尔差更稳定，也更不容易让 AI 算错内腔高度与中心点。"
        ],
        "inputExpectation": "该 action 不依赖前序几何输入。",
        "outputMeaning": "输出是带统一壁厚且沿指定方向开口的盒状壳体实体，可继续开孔、添加凸耳或做装配特征。",
        "example": {
          "id": "solid_hollowBox_example",
          "action": "solid.hollowBox",
          "params": {
            "size": [
              180,
              120,
              18
            ],
            "center": [
              0,
              0,
              9
            ],
            "wallThickness": 3,
            "openAxis": "z",
            "openSide": "negative"
          }
        }
      }
    },
