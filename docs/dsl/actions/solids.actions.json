    "solid.polyhedron": {
      "role": "通过顶点和面定义任意三维网格实体",
      "inputKinds": [],
      "outputKind": "geom3",
      "paramsSchema": {
        "type": "object",
        "required": [
          "points",
          "faces"
        ],
        "properties": {
