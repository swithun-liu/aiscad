            "enum": [
              "outward",
              "inward"
            ],
            "default": "outward"
          }
        },
        "additionalProperties": false
      },
      "llm": {
        "webSupported": true,
        "summary": "通过顶点和面定义任意三维网格实体",
        "requiredParams": [
          "points",
          "faces"
        ],
        "paramGuide": {
          "points": "point3[]，三维点数组。顶点坐标列表，所有 faces 都只能引用这里的索引。",
          "faces": "array，数组。面索引列表；每个面至少 3 个顶点索引，且应共同构成闭合实体。",
          "orientation": "enum，可选值：outward / inward。 多面体面朝向。 默认值 \"outward\"。"
        },
        "constraints": [
          "faces 中的索引必须引用 points 中存在的顶点。",
          "各个面应共同构成闭合实体，面朝向需尽量一致；否则可能出现缺面、翻面或看起来像空壳。",
          "当目标只是规则小特征、斜面台阶或局部回钩时，不要优先使用 polyhedron。"
        ],
        "whenToUse": [
          "标准 primitive、二维草图拉伸或回转都难以表达时使用。",
          "需要显式控制顶点位置与面连接关系，或需要构造非标准网格实体时使用。"
        ],
        "whenNotToUse": [
          "不要把 polyhedron 当成做小型规则特征的首选，例如简单凸耳、台阶、回钩、肋或规则斜面。",
          "当结构可以用 sketch + construct.extrudeLinear，或 primitive + boolean 更稳定表达时，不要优先使用它。"
        ],
        "commonMistakes": [
          "faces 的顶点顺序不一致，导致法线翻转、缺面或透明预览时像空壳。",
          "面没有真正闭合成实体，或不同面之间存在缝隙、重叠和自交。",
          "顶点索引写错，引用了不存在的点，或同一局部特征本可用更简单 action 却强行使用 polyhedron。"
        ],
        "recommendedBefore": [],
        "recommendedAfter": [
          "transform.translate",
          "transform.rotate",
          "boolean.union",
          "boolean.subtract"
        ],
        "stabilityNotes": [
          "polyhedron 自由度高但风险也高；对 AI 来说比 primitive、polygon + extrude 或 boolean 路线更容易出错。",
          "规则小特征优先使用 primitive + boolean；带角度的截面优先使用 sketch.polygon + construct.extrudeLinear。"
        ],
        "inputExpectation": "该 action 不依赖前序几何输入，但 points 与 faces 必须成套设计，不能只凭局部感觉临时拼接。",
        "outputMeaning": "输出是由显式顶点和面定义的三维实体，适合表达非标准网格形体，但稳定性依赖顶点与面的拓扑质量。",
        "example": {
