    "solid.box": {
      "role": "生成长方体",
      "inputKinds": [],
      "outputKind": "geom3",
      "paramsSchema": {
        "type": "object",
        "required": [
          "size"
        ],
        "properties": {
          "size": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/vector3"
          },
          "center": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/vector3",
            "default": [
              0,
              0,
              0
            ]
          }
        },
        "additionalProperties": false
      },
      "llm": {
        "webSupported": true,
        "summary": "生成长方体",
        "requiredParams": [
          "size"
        ],
        "paramGuide": {
          "size": "vector3，长度为 3 的数值数组。 尺寸向量。2D 时为 [x, y]，3D 时为 [x, y, z]。",
          "center": "vector3，长度为 3 的数值数组。 中心点坐标。 默认值 [0, 0, 0]。"
        },
        "constraints": [],
        "whenToUse": [
          "可以直接用基础体表达主体时优先使用。",
          "当结构接近标准几何原语时，优先用 solid 而不是复杂草图。"
        ],
        "whenNotToUse": [
          "不要为了拟合简单结构而放弃更稳定的 primitive 路线。"
        ],
        "commonMistakes": [
          "基础体尺寸与中心点理解错误，导致后续布尔位置整体偏移。"
        ],
        "recommendedBefore": [],
        "recommendedAfter": [
          "transform.translate",
          "transform.rotate",
          "boolean.union",
          "boolean.subtract"
        ],
        "stabilityNotes": [
          "primitive + transform + boolean 通常比一次性构造复杂轮廓更稳。"
        ],
        "inputExpectation": "该 action 不依赖前序几何输入。",
        "outputMeaning": "输出是三维实体，可作为可打印或实体布尔阶段的基础。",
        "example": {
          "id": "solid_box_example",
          "action": "solid.box",
          "params": {
            "size": [
              40,
              20,
              10
            ],
            "center": [
              0,
              0,
              0
            ]
          }
        }
      }
    },
