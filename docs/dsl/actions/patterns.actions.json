{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aiscad.dsl/actions/patterns",
  "category": "patterns",
  "actions": {
    "pattern.linear": {
      "role": "按单方向线性阵列复制对象",
      "inputKinds": [
        "curve2",
        "geom2",
        "geom3",
        "group"
      ],
      "outputKind": "group",
      "paramsSchema": {
        "type": "object",
        "required": [
          "source",
          "count",
          "step"
        ],
        "properties": {
          "source": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/ref"
          },
          "count": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/integerValue"
          },
          "step": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/vector3"
          },
          "origin": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/vector3",
            "default": [
              0,
              0,
              0
            ]
          }
        },
        "additionalProperties": false
      },
      "llm": {
        "webSupported": true,
        "summary": "按单方向线性阵列复制对象",
        "requiredParams": [
          "source",
          "count",
          "step"
        ],
        "paramGuide": {
          "source": "ref，字符串，引用前序 action 的 id。要被重复的基础对象或分组。",
          "count": "integer，整数，或 {\"$var\":\"变量名\"}。线性阵列的总实例数，必须是整数。",
          "step": "vector3，长度为 3 的数值数组。相邻两个实例之间的位移步长。",
          "origin": "vector3，长度为 3 的数值数组。首个实例的附加偏移，不是整组中心点。 默认值 [0, 0, 0]。"
        },
        "constraints": [],
        "whenToUse": [
          "需要沿单一方向、同一条边或同一直线重复特征时使用。",
          "适合同边的多个孔、凸耳、肋、安装位或等距单元。"
        ],
        "whenNotToUse": [
          "不要用 linear 表达二维网格；那更适合 pattern.grid。",
          "不要用 linear 表达对边对称副本；那更适合 transform.mirror。"
        ],
        "commonMistakes": [
          "把 count 理解成额外副本数量，而不是总实例数。",
          "把 origin 当成整组中心，导致阵列整体偏移。"
        ],
        "recommendedBefore": [
          "solid.cylinder",
          "sketch.circle",
          "transform.translate"
        ],
        "recommendedAfter": [
          "boolean.union",
          "boolean.subtract",
          "transform.mirror",
          "display.group"
        ],
        "stabilityNotes": [
          "linear 更适合先把单个特征定义清楚，再沿一个方向复制，不要同时承担定位和裁边。"
        ],
        "inputExpectation": "输入通常来自这些类型之一：curve2 / geom2 / geom3 / group。",
        "outputMeaning": "输出是 group，按 step 从 origin 开始线性排列 count 个实例。",
        "example": {
          "id": "pattern_linear_example",
          "action": "pattern.linear",
          "params": {
            "source": "unit",
            "count": 4,
            "step": [
              20,
              0,
              0
            ],
            "origin": [
              0,
              0,
              0
            ]
          }
        }
      }
    },
    "pattern.grid": {
      "role": "按三轴网格阵列复制对象",
      "inputKinds": [
        "curve2",
        "geom2",
        "geom3",
        "group"
      ],
      "outputKind": "group",
      "paramsSchema": {
        "type": "object",
        "required": [
          "source",
          "count",
          "step"
        ],
        "properties": {
          "source": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/ref"
          },
          "count": {
            "type": "array",
            "items": {
              "$ref": "aiscad.dsl/actions/common.types#/$defs/integerValue"
            },
            "minItems": 3,
            "maxItems": 3
          },
          "step": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/vector3"
          },
          "origin": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/vector3",
            "default": [
              0,
              0,
              0
            ]
          }
        },
        "additionalProperties": false
      },
      "llm": {
        "webSupported": true,
        "summary": "按三轴网格阵列复制对象",
        "requiredParams": [
          "source",
          "count",
          "step"
        ],
        "paramGuide": {
          "source": "ref，字符串，引用前序 action 的 id。要被重复的基础对象或分组。",
          "count": "array，固定长度 3。分别表示 x/y/z 三个方向上的总实例数，必须写成 [nx, ny, nz]。",
          "step": "vector3，长度为 3 的数值数组。x/y/z 三个方向上相邻实例的步长。",
          "origin": "vector3，长度为 3 的数值数组。首个实例的附加偏移，不是整个网格中心。 默认值 [0, 0, 0]。"
        },
        "constraints": [],
        "whenToUse": [
          "需要在平面或体积中按行列/层规则重复单元时使用。",
          "适合孔阵、格栅、规则分布的加强特征和重复单元。"
        ],
        "whenNotToUse": [
          "不要用 grid 表达单边一列重复；那更适合 pattern.linear。",
          "不要假设 grid 自带裁边或保留外框；它只负责复制。"
        ],
        "commonMistakes": [
          "把 count 写成单个数，而不是 [x, y, z]。",
          "把 origin 当成整个网格中心，导致阵列落位错误。",
          "count 很大却没有控制边界，导致后续布尔或预览复杂度暴涨。"
        ],
        "recommendedBefore": [
          "solid.cylinder",
          "sketch.circle",
          "transform.translate"
        ],
        "recommendedAfter": [
          "boolean.subtract",
          "boolean.intersect",
          "display.group"
        ],
        "stabilityNotes": [
          "grid 适合先生成规则单元集合，再由其他 action 决定是否裁边或参与布尔。"
        ],
        "inputExpectation": "输入通常来自这些类型之一：curve2 / geom2 / geom3 / group。",
        "outputMeaning": "输出是 group，实例沿 x/y/z 方向形成规则网格排列。",
        "example": {
          "id": "pattern_grid_example",
          "action": "pattern.grid",
          "params": {
            "source": "unit",
            "count": [
              2,
              2,
              1
            ],
            "step": [
              20,
              20,
              0
            ],
            "origin": [
              0,
              0,
              0
            ]
          }
        }
      }
    },
    "pattern.radial": {
      "role": "按圆周阵列复制对象",
      "inputKinds": [
        "curve2",
        "geom2",
        "geom3",
        "group"
      ],
      "outputKind": "group",
      "paramsSchema": {
        "type": "object",
        "required": [
          "source",
          "count",
          "radius"
        ],
        "properties": {
          "source": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/ref"
          },
          "count": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/integerValue"
          },
          "radius": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/numberValue"
          },
          "startAngle": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/numberValue",
            "default": 0
          },
          "sweepAngle": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/numberValue",
            "default": 360
          },
          "axis": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/axis",
            "default": "z"
          },
          "center": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/vector3",
            "default": [
              0,
              0,
              0
            ]
          },
          "rotateItems": {
            "$ref": "aiscad.dsl/actions/common.types#/$defs/booleanValue",
            "default": true
          }
        },
        "additionalProperties": false
      },
      "llm": {
        "webSupported": true,
        "summary": "按圆周阵列复制对象",
        "requiredParams": [
          "source",
          "count",
          "radius"
        ],
        "paramGuide": {
          "source": "ref，字符串，引用前序 action 的 id。要被绕轴复制的基础对象或分组。",
          "count": "integer，整数，或 {\"$var\":\"变量名\"}。圆周上的总实例数。",
          "radius": "number，数值，或 {\"$var\":\"变量名\"}。阵列半径；若为 0，实例会重叠在轴心附近。",
          "startAngle": "number，数值，或 {\"$var\":\"变量名\"}。起始角度，单位为度。 默认值 0。",
          "sweepAngle": "number，数值，或 {\"$var\":\"变量名\"}。沿圆周分布的总扫掠角度，单位为度。 默认值 360。",
          "axis": "enum，只能是 x、y、z。 阵列围绕的坐标轴。 默认值 \"z\"。",
          "center": "vector3，长度为 3 的数值数组。阵列圆心坐标。 默认值 [0, 0, 0]。",
          "rotateItems": "boolean，布尔值，或 {\"$var\":\"变量名\"}。每个副本是否随圆周方向同步旋转。 默认值 true。"
        },
        "constraints": [],
        "whenToUse": [
          "需要围绕某个中心轴做圆周均布时使用。",
          "适合法兰孔、叶片、轮辐、圆周耳位等环形重复特征。"
        ],
        "whenNotToUse": [
          "不要用 radial 表达对边或左右两侧分布；那更适合 mirror 或 linear。",
          "不要把 radius 设为 0 只为了复制对象；这通常会导致实例重叠。"
        ],
        "commonMistakes": [
          "把 radial 当成普通对称复制，结果特征跑到不该去的方位。",
          "radius 为 0 或 center/axis 设错，导致实例重叠或转轴错误。",
          "未判断 rotateItems 是否需要开启，导致副本朝向不符合预期。"
        ],
        "recommendedBefore": [
          "solid.cylinder",
          "sketch.circle",
          "transform.translate"
        ],
        "recommendedAfter": [
          "boolean.union",
          "boolean.subtract",
          "display.group"
        ],
        "stabilityNotes": [
          "只有当特征确实围绕同一轴心重复时再用 radial；少量对称特征通常更适合 mirror。"
        ],
        "inputExpectation": "输入通常来自这些类型之一：curve2 / geom2 / geom3 / group。",
        "outputMeaning": "输出是 group，实例分布在指定 axis 的圆周上，可选是否随角度同步旋转。",
        "example": {
          "id": "pattern_radial_example",
          "action": "pattern.radial",
          "params": {
            "source": "unit",
            "count": 6,
            "radius": 30,
            "startAngle": 0,
            "sweepAngle": 360,
            "axis": "z",
            "center": [
              0,
              0,
              0
            ],
            "rotateItems": true
          }
        }
      }
    }
  },
  "llm": {
    "purpose": "阵列复制类 action 定义。",
    "readAs": "这份 JSON 可以直接提供给大模型阅读；优先看每个 action 下的 llm 字段，再遵守 paramsSchema。",
    "actionReadingOrder": [
      "先看 summary 判断作用。",
      "再看 whenToUse / whenNotToUse / commonMistakes 选择是否使用。",
      "再按 requiredParams 与 paramGuide 填参数。",
      "最后参考 recommendedBefore / recommendedAfter / stabilityNotes 组织 action 顺序。"
    ]
  }
}
